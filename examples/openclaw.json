{
  "mcpServers": {
    "aiperture": {
      "command": "aiperture",
      "args": ["mcp-serve"],
      "env": {
        "AIPERTURE_DB_PATH": "./aiperture.db",
        "AIPERTURE_PERMISSION_LEARNING_MIN_DECISIONS": "3",
        "AIPERTURE_AUTO_APPROVE_THRESHOLD": "0.80",
        "AIPERTURE_AUTO_DENY_THRESHOLD": "0.05"
      }
    }
  }
}
